# WMS - 仓库管理系统
# ===================
# 复制此文件为 .env 并修改配置

# 数据库
DATABASE_URL="postgresql://wms:wms_password@localhost:5432/wms?schema=public"

# JWT 密钥（生产环境请使用强随机字符串）
JWT_SECRET="change...cret"
JWT_EXPIRES_IN=7d

# 后端端口
APP_PORT=3001

# CORS 允许的前端地址
CORS_ORIGIN="http://localhost:3000"

# 默认管理员账号
DEFAULT_ADMIN_EMAIL="admin@example.com"
DEFAULT_ADMIN_PASSWORD="ChangeMe123!"
DEFAULT_ADMIN_NAME="Admin"

# 运行环境
NODE_ENV="development"
LOG_LEVEL="info"

# WMS-A 部署配置
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=wms
POSTGRES_PASSWORD=*** --- Backend ---
NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://wms:***@postgres:5432/wms?schema=public
JWT_SECRET=*** --- Default admin seed ---
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=*** --- Frontend ---
VITE_API_BASE_URL=/api
FRONTEND_PORT=80

# --- Internal network HTTPS ---
WMS_DOMAIN=wms.factory.os
WMS_PUBLIC_URL=https://wms.factory.os
CORS_ORIGIN=https://wms.factory.os

# Production notes
# Change JWT_SECRET before production deployment.
# Change DEFAULT_ADMIN_PASSWORD before production deployment.
# Do not commit .env.
# For HTTPS deployment, see docs/internal-ca-https.md

# WMS - 仓库管理系统
# ===================
# 复制此文件为 .env 并修改配置
# cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=wms
POSTGRES_PASSWORD=wms_password
POSTGRES_DB=wms
POSTGRES_PORT=5432

# --- Backend ---
NODE_ENV=production
PORT=3001
DATABASE_URL="postgresql://wms:wms_password@postgres:5432/wms?schema=public"
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost

# --- Default Admin (Seed) ---
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=ChangeMe123!
DEFAULT_ADMIN_NAME=Admin

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:3001/api
FRONTEND_PORT=80
